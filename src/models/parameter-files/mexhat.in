#Evolution
expansion = true
evolver = LF

#Output
outputfile = /home/morten/GoetheUni/DMGW_Project/cosmolattice/output/mH1e4/

#Model Parameters
lambda = 8.333E-10
mu = 2.435E+10

#Lattice
N = 64
dt = 0.01
kIR = 0.1

#Times
tOutputFreq = 1
tOutputInfreq = 1
tMax = 1
# baseSeed = 1234

#Power spectrum options
PS_type = 1
PS_version = 1

#GWs
GWprojectorType = 1
withGWs=true

#IC
kCutOff = 4
initial_amplitudes = 1e12 # homogeneous amplitudes in GeV
initial_momenta = 0 # homogeneous amplitudes in GeV2

