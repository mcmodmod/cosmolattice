# Evolution
expansion = true
evolver = LF

#Output
outputfile = ../output/

#Model Parameters
lambda = 0.01
mu = 1

#Lattice
N = 32
dt = 0.05
kIR = 0.1

#Times
tOutputFreq = 10
tOutputInfreq = 10
tMax = 100
baseSeed = 1234

#Power spectrum options
PS_type = 1
PS_version = 1

#GWs
GWprojectorType = 1
withGWs=true

#IC
kCutOff = 4
initial_amplitudes = 0 # homogeneous amplitudes in GeV
initial_momenta = 0 # homogeneous amplitudes in GeV2

