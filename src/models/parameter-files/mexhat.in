#Evolution
expansion = true
evolver = LF

#Output
outputfile = /home/will/cosmolattice/output/mH100/

#Model Parameters
lambda = 8.33E-14
mu = 2.44E+10   

#Lattice
N = 32
dt = 0.01
kIR = 0.1

#Times
tOutputFreq = 10
tOutputInfreq = 10
tMax = 500
baseSeed = 1234

#Power spectrum options
PS_type = 1
PS_version = 1

#GWs
GWprojectorType = 1
withGWs=true

#IC
kCutOff = 4
initial_amplitudes = 0 # homogeneous amplitudes in GeV
initial_momenta = 0 # homogeneous amplitudes in GeV2

